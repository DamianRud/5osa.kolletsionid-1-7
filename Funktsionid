        public static void list_Remove()
        {
            List<string> people = new List<string>() { "Kadi", "Mirje" };

            foreach (string p in people)
                Console.WriteLine(p);

            people.Add("Lisa");
            people.Remove("Lisa");

            Console.WriteLine("pärast eemaldamine Lisa:");
            foreach (string p in people)
                Console.WriteLine(p);

            people.RemoveAt(0);
            people.Insert(0, "Anna");
